status.vayki.com {
    # Route API traffic to the backend on port 8080
    handle /api/* {
        reverse_proxy backend:8080
    }

    # Route WebSocket traffic to the backend on port 8080
    handle /ws* {
        uri strip_prefix /ws
        reverse_proxy backend:8080
    }

    # Route all other traffic to the frontend on port 80
    handle {
        reverse_proxy frontend:80
    }
}
